---
import "../styles/global.css";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  title?: string;
  description?: string;
  jsonLd?: object; // datos estructurados Schema.org opcionales, por página
}

const {
  title = t("meta.title"),
  description = t("meta.description"),
  jsonLd,
} = Astro.props;

// URL canónica de esta página (evita contenido duplicado a ojos de Google)
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO: contenido servido en HTML, visible para buscadores y crawlers de IA -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- hreflang: le dice a Google que existen versiones en cada idioma -->
    <link rel="alternate" hreflang="es" href={new URL("/", Astro.site ?? Astro.url.origin).href} />
    <link rel="alternate" hreflang="en" href={new URL("/en/", Astro.site ?? Astro.url.origin).href} />
    <link rel="alternate" hreflang="x-default" href={new URL("/", Astro.site ?? Astro.url.origin).href} />

    <!-- Datos estructurados (Schema.org). Le explican a Google y a las IA qué es esta página. -->
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <!-- Tipografías: Fraunces (display) + Inter (cuerpo) + IBM Plex Mono (datos) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
