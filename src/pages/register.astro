---
// Página de registro. SSR.
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import AuthForm from "../components/AuthForm.astro";
import { createSupabaseServerClient } from "../lib/supabase";
import { useTranslations, getLangFromUrl } from "../i18n/utils";

const t = useTranslations(getLangFromUrl(Astro.url));

const supabase = createSupabaseServerClient(Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (user) return Astro.redirect("/account");

const url = new URL(Astro.request.url);
const error = url.searchParams.get("error") ? t("auth.error.generic") : null;
---

<BaseLayout title={t("auth.register.title")}>
  <Header />
  <AuthForm mode="register" error={error} />
</BaseLayout>
