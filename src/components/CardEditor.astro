---
// CardEditor.astro — el editor. Los textos de la interfaz ahora se traducen;
// la lógica del canvas (Fabric.js) recibe los valores por defecto del idioma.
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { createSupabaseServerClient } from "../lib/supabase";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// ¿Hay sesión? Solo mostramos "Guardar" si el usuario está logueado.
let loggedIn = false;
try {
  const supabase = createSupabaseServerClient(Astro.cookies);
  const { data: { user } } = await supabase.auth.getUser();
  loggedIn = !!user;
} catch {
  loggedIn = false;
}
---

<section class="mx-auto max-w-5xl px-6 py-10">
  <div class="grid gap-8 lg:grid-cols-[1fr_340px]">
    <!-- Previsualización de la tarjeta -->
    <div class="flex flex-col items-center">
      <div class="rounded-xl border border-[var(--color-borde)] bg-white p-4 shadow-sm">
        <canvas
          id="card-canvas"
          width="600"
          height="600"
          data-quote={t("editor.quote.default")}
          data-author={t("editor.author.default")}
        ></canvas>
      </div>
      <p class="mt-3 font-[family-name:var(--font-mono)] text-xs text-[var(--color-humo)]">
        {t("editor.dimensions")}
      </p>
    </div>

    <!-- Controles -->
    <div class="flex flex-col gap-6">
      <div>
        <label for="quote-text" class="mb-2 block font-[family-name:var(--font-display)] text-lg text-[var(--color-tinta)]">
          {t("editor.quote.label")}
        </label>
        <textarea
          id="quote-text"
          rows="4"
          class="w-full resize-none rounded-md border border-[var(--color-borde)] bg-[var(--color-lino)] px-3 py-2 text-sm text-[var(--color-tinta)] focus:border-[var(--color-musgo)] focus:outline-none"
          placeholder={t("editor.quote.placeholder")}
          set:text={t("editor.quote.default")}
        ></textarea>
      </div>

      <div>
        <label for="author-text" class="mb-2 block font-[family-name:var(--font-display)] text-lg text-[var(--color-tinta)]">
          {t("editor.author.label")}
        </label>
        <input
          id="author-text"
          type="text"
          value={t("editor.author.default")}
          class="w-full rounded-md border border-[var(--color-borde)] bg-[var(--color-lino)] px-3 py-2 text-sm text-[var(--color-tinta)] focus:border-[var(--color-musgo)] focus:outline-none"
        />
      </div>

      <div>
        <span class="mb-2 block font-[family-name:var(--font-display)] text-lg text-[var(--color-tinta)]">
          {t("editor.bg.label")}
        </span>
        <div class="flex gap-2" id="bg-swatches">
          <button data-bg="#f3efe6" class="swatch h-9 w-9 rounded-full border border-[var(--color-borde)]" style="background:#f3efe6" aria-label="Lino"></button>
          <button data-bg="#4a5d43" class="swatch h-9 w-9 rounded-full border border-[var(--color-borde)]" style="background:#4a5d43" aria-label="Musgo"></button>
          <button data-bg="#22201b" class="swatch h-9 w-9 rounded-full border border-[var(--color-borde)]" style="background:#22201b" aria-label="Tinta"></button>
          <button data-bg="#a6572f" class="swatch h-9 w-9 rounded-full border border-[var(--color-borde)]" style="background:#a6572f" aria-label="Óxido"></button>
          <button data-bg="#e9e3d5" class="swatch h-9 w-9 rounded-full border border-[var(--color-borde)]" style="background:#e9e3d5" aria-label="Papel"></button>
        </div>
      </div>

      <div>
        <span class="mb-2 block font-[family-name:var(--font-display)] text-lg text-[var(--color-tinta)]">
          {t("editor.font.label")}
        </span>
        <div class="flex gap-2" id="font-options">
          <button data-font="Fraunces" class="font-btn flex-1 rounded-md border border-[var(--color-borde)] px-3 py-2 text-sm" style="font-family:Fraunces,serif">{t("editor.font.serif")}</button>
          <button data-font="Inter" class="font-btn flex-1 rounded-md border border-[var(--color-borde)] px-3 py-2 text-sm" style="font-family:Inter,sans-serif">{t("editor.font.sans")}</button>
          <button data-font="IBM Plex Mono" class="font-btn flex-1 rounded-md border border-[var(--color-borde)] px-3 py-2 text-sm" style="font-family:'IBM Plex Mono',monospace">{t("editor.font.mono")}</button>
        </div>
      </div>

      <button
        id="download-btn"
        class="mt-2 rounded-md bg-[var(--color-oxido)] px-4 py-3 text-sm font-500 text-[var(--color-lino)] transition-colors hover:brightness-110"
      >
        {t("editor.download")}
      </button>

      {loggedIn ? (
        <button
          id="save-btn"
          data-saved={t("cards.saved")}
          data-error={t("cards.saveError")}
          class="rounded-md border border-[var(--color-musgo)] px-4 py-3 text-sm font-500 text-[var(--color-musgo)] transition-colors hover:bg-[var(--color-musgo)] hover:text-[var(--color-lino)]"
        >
          {t("cards.save")}
        </button>
      ) : (
        <a
          href="/login"
          class="text-center text-xs text-[var(--color-humo)] underline hover:text-[var(--color-tinta)]"
        >
          {t("cards.loginToSave")}
        </a>
      )}
      <span id="save-status" class="text-center text-xs text-[var(--color-musgo)]"></span>
    </div>
  </div>
</section>

<script>
  // El editor interactivo. Corre solo en el navegador.
  import * as fabric from "fabric";

  const HEX_CLARO = "#f3efe6";
  const HEX_OSCURO = "#22201b";

  const canvasEl = document.getElementById("card-canvas") as HTMLCanvasElement;

  // Los valores por defecto vienen del HTML (ya traducidos según el idioma)
  const state = {
    quote: canvasEl?.dataset.quote || "",
    author: canvasEl?.dataset.author || "",
    bg: "#f3efe6",
    font: "Fraunces",
  };

  const canvas = new fabric.Canvas("card-canvas", {
    backgroundColor: state.bg,
    selection: false,
  });

  function textColorFor(bg: string): string {
    return bg === HEX_OSCURO || bg === "#4a5d43" || bg === "#a6572f" ? HEX_CLARO : HEX_OSCURO;
  }

  function render() {
    canvas.clear();
    canvas.backgroundColor = state.bg;
    const color = textColorFor(state.bg);

    const markObj = new fabric.Textbox("\u201C", {
      left: 60, top: 40, width: 200, fontSize: 120, fontFamily: state.font,
      fill: color, opacity: 0.25, selectable: false, evented: false,
    });

    const quoteObj = new fabric.Textbox(state.quote, {
      left: 60, top: 180, width: 480, fontSize: 40, lineHeight: 1.2, fontFamily: state.font,
      fontStyle: state.font === "Fraunces" ? "italic" : "normal",
      fill: color, selectable: false, evented: false,
    });

    const authorObj = new fabric.Textbox("\u2014 " + state.author, {
      left: 60, top: 500, width: 480, fontSize: 20, fontFamily: "IBM Plex Mono",
      fill: color, opacity: 0.75, selectable: false, evented: false,
    });

    canvas.add(markObj, quoteObj, authorObj);
    canvas.renderAll();
  }

  const quoteInput = document.getElementById("quote-text") as HTMLTextAreaElement;
  quoteInput?.addEventListener("input", (e) => {
    state.quote = (e.target as HTMLTextAreaElement).value;
    render();
  });

  const authorInput = document.getElementById("author-text") as HTMLInputElement;
  authorInput?.addEventListener("input", (e) => {
    state.author = (e.target as HTMLInputElement).value;
    render();
  });

  document.querySelectorAll<HTMLButtonElement>("#bg-swatches .swatch").forEach((btn) => {
    btn.addEventListener("click", () => { state.bg = btn.dataset.bg!; render(); });
  });

  document.querySelectorAll<HTMLButtonElement>("#font-options .font-btn").forEach((btn) => {
    btn.addEventListener("click", () => { state.font = btn.dataset.font!; render(); });
  });

  document.getElementById("download-btn")?.addEventListener("click", () => {
    const dataURL = canvas.toDataURL({ format: "png", multiplier: 2 });
    const link = document.createElement("a");
    link.download = "tarjeta.png";
    link.href = dataURL;
    link.click();
  });

  // Guardar la tarjeta (solo existe el botón si hay sesión)
  const saveBtn = document.getElementById("save-btn") as HTMLButtonElement | null;
  const saveStatus = document.getElementById("save-status");
  saveBtn?.addEventListener("click", async () => {
    saveBtn.disabled = true;
    try {
      const res = await fetch("/api/cards/save", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        // Guardamos el estado (texto, autor, fondo, fuente). Simple y suficiente
        // para reconstruir la tarjeta después.
        body: JSON.stringify(state),
      });
      if (!res.ok) throw new Error("save failed");
      if (saveStatus) saveStatus.textContent = saveBtn.dataset.saved || "OK";
    } catch {
      if (saveStatus) saveStatus.textContent = saveBtn.dataset.error || "Error";
    } finally {
      saveBtn.disabled = false;
      setTimeout(() => { if (saveStatus) saveStatus.textContent = ""; }, 2500);
    }
  });

  document.fonts.ready.then(render);
</script>
