---
// HomeContent.astro — el cuerpo de la home, compartido por ambos idiomas.
// Así el español y el inglés usan exactamente la misma estructura;
// solo cambian los textos (vía el diccionario).
import Header from "./Header.astro";
import CardEditor from "./CardEditor.astro";
import Footer from "./Footer.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Header />

<main>
  <section class="mx-auto max-w-5xl px-6 pt-12 pb-2 text-center">
    <p class="mb-3 font-[family-name:var(--font-mono)] text-xs uppercase tracking-widest text-[var(--color-musgo)]">
      {t("hero.eyebrow")}
    </p>
    <h1 class="mx-auto max-w-2xl font-[family-name:var(--font-display)] text-4xl leading-tight text-[var(--color-tinta)] sm:text-5xl">
      {t("hero.title")}
    </h1>
    <p class="mx-auto mt-4 max-w-md text-[var(--color-humo)]">
      {t("hero.subtitle")}
    </p>
  </section>

  <CardEditor />
</main>

<Footer />
