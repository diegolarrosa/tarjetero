---
// Header.astro — ahora conoce el estado de sesión.
// Si hay usuario: muestra "Tu cuenta" + "Salir". Si no: "Ingresar".
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { createSupabaseServerClient } from "../lib/supabase";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const homeHref = lang === "es" ? "/" : "/en/";

// Leemos la sesión. En páginas estáticas no hay cookies de servidor,
// así que envolvemos en try/catch para que el Header funcione en ambos casos.
let user = null;
try {
  const supabase = createSupabaseServerClient(Astro.cookies);
  const result = await supabase.auth.getUser();
  user = result.data.user;
} catch {
  user = null;
}
---

<header class="border-b border-[var(--color-borde)]">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-5">
    <a href={homeHref} class="group flex items-baseline gap-2">
      <span class="font-[family-name:var(--font-display)] text-2xl font-600 tracking-tight text-[var(--color-tinta)]">
        Tarjetero
      </span>
      <span class="font-[family-name:var(--font-mono)] text-xs text-[var(--color-humo)]">v0.1</span>
    </a>

    <nav class="flex items-center gap-6">
      <a href={homeHref} class="text-sm text-[var(--color-humo)] transition-colors hover:text-[var(--color-tinta)]">
        {t("nav.editor")}
      </a>
      <a href="/frases" class="hidden text-sm text-[var(--color-humo)] transition-colors hover:text-[var(--color-tinta)] sm:inline">
        Frases
      </a>
      <a href="/guia" class="hidden text-sm text-[var(--color-humo)] transition-colors hover:text-[var(--color-tinta)] sm:inline">
        Guía
      </a>

      <div class="flex items-center gap-1 font-[family-name:var(--font-mono)] text-xs">
        <a href="/" class={`px-1.5 py-0.5 rounded transition-colors ${lang === "es" ? "bg-[var(--color-musgo)] text-[var(--color-lino)]" : "text-[var(--color-humo)] hover:text-[var(--color-tinta)]"}`} aria-label="Ver en español">ES</a>
        <span class="text-[var(--color-borde)]">/</span>
        <a href="/en/" class={`px-1.5 py-0.5 rounded transition-colors ${lang === "en" ? "bg-[var(--color-musgo)] text-[var(--color-lino)]" : "text-[var(--color-humo)] hover:text-[var(--color-tinta)]"}`} aria-label="View in English">EN</a>
      </div>

      {user ? (
        <div class="flex items-center gap-3">
          <a href="/account" class="text-sm text-[var(--color-humo)] transition-colors hover:text-[var(--color-tinta)]">
            {t("auth.account.title")}
          </a>
          <form method="POST" action="/api/auth/signout">
            <button type="submit" class="rounded-md bg-[var(--color-musgo)] px-4 py-2 text-sm font-500 text-[var(--color-lino)] transition-colors hover:bg-[var(--color-musgo-claro)]">
              {t("auth.logout")}
            </button>
          </form>
        </div>
      ) : (
        <a href="/login" class="rounded-md bg-[var(--color-musgo)] px-4 py-2 text-sm font-500 text-[var(--color-lino)] transition-colors hover:bg-[var(--color-musgo-claro)]">
          {t("auth.login")}
        </a>
      )}
    </nav>
  </div>
</header>
